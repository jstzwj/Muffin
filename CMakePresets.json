{
    "version": 3,
    "configurePresets": [
        {
            "name": "dev",
            "binaryDir": "${sourceDir}/build/dev",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BUILD_TESTING": "ON"
            }
        },
        {
            "name": "release",
            "binaryDir": "${sourceDir}/build/release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "BUILD_TESTING": "OFF"
            }
        },
        {
            "name": "release-test",
            "inherits": "release",
            "binaryDir": "${sourceDir}/build/release-test",
            "cacheVariables": {
                "BUILD_TESTING": "ON"
            }
        },
        {
            "name": "conan",
            "hidden": true,
            "toolchainFile": "${sourceDir}/build/generators/conan_toolchain.cmake"
        },
        {
            "name": "dev-conan",
            "inherits": ["dev", "conan"],
            "binaryDir": "${sourceDir}/build/dev"
        },
        {
            "name": "release-conan",
            "inherits": ["release", "conan"],
            "binaryDir": "${sourceDir}/build/release"
        },
        {
            "name": "release-test-conan",
            "inherits": ["release-test", "conan"],
            "binaryDir": "${sourceDir}/build/release-test"
        }
    ],
    "buildPresets": [
        {
            "name": "dev",
            "configurePreset": "dev"
        },
        {
            "name": "dev-conan",
            "configurePreset": "dev-conan"
        },
        {
            "name": "release",
            "configurePreset": "release"
        },
        {
            "name": "release-conan",
            "configurePreset": "release-conan"
        },
        {
            "name": "release-test-conan",
            "configurePreset": "release-test-conan"
        }
    ]
}
