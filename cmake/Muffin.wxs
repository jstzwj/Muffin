<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="Muffin"
    Manufacturer="Muffin"
    Version="$(var.MuffinVersion)"
    UpgradeCode="b5e2b3a0-1234-4d5e-8f9a-1b2c3d4e5f6a"
    Language="1033"
    Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Muffin is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="Muffin">
        <Directory Id="PlatformsDir" Name="platforms" />
        <Directory Id="StylesDir" Name="styles" />
        <Directory Id="ImageformatsDir" Name="imageformats" />
      </Directory>
    </StandardDirectory>

    <Feature Id="MainFeature" Title="Muffin" Level="1">
      <ComponentGroupRef Id="MuffinMainFiles" />
      <ComponentGroupRef Id="MuffinPlatformsPlugins" />
      <ComponentGroupRef Id="MuffinStylesPlugins" />
      <ComponentGroupRef Id="MuffinImageformatsPlugins" />
      <ComponentRef Id="ApplicationShortcut" />
    </Feature>

    <!-- Start Menu shortcut -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="Muffin">
        <Component Id="ApplicationShortcut" Guid="c1a2b3c4-d5e6-4f7a-8b9c-0d1e2f3a4b5c">
          <Shortcut Id="ApplicationStartMenuShortcut"
            Name="Muffin"
            Target="[INSTALLFOLDER]Muffin.exe"
            WorkingDirectory="INSTALLFOLDER" />
          <RemoveFolder Id="RemoveApplicationProgramsFolder"
            Directory="ApplicationProgramsFolder"
            On="uninstall" />
          <RegistryValue Root="HKCU"
            Key="Software\Muffin"
            Name="installed"
            Type="integer"
            Value="1"
            KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

  </Package>

  <!-- Main directory files: exe, dlls, qt.conf -->
  <Fragment>
    <ComponentGroup Id="MuffinMainFiles" Directory="INSTALLFOLDER">
      <Component Id="MuffinExe" Guid="d2e3f4a5-b6c7-4d8e-9f0a-1b2c3d4e5f6a">
        <File Id="MuffinExeFile" Source="$(var.DistDir)/Muffin.exe" KeyPath="yes" />
      </Component>
      <Component Id="Qt6Core" Guid="*">
        <File Id="Qt6CoreDll" Source="$(var.DistDir)/Qt6Core.dll" />
      </Component>
      <Component Id="Qt6Gui" Guid="*">
        <File Id="Qt6GuiDll" Source="$(var.DistDir)/Qt6Gui.dll" />
      </Component>
      <Component Id="Qt6Svg" Guid="*">
        <File Id="Qt6SvgDll" Source="$(var.DistDir)/Qt6Svg.dll" />
      </Component>
      <Component Id="Qt6Widgets" Guid="*">
        <File Id="Qt6WidgetsDll" Source="$(var.DistDir)/Qt6Widgets.dll" />
      </Component>
      <Component Id="QtConf" Guid="c7d8e9f0-a1b2-4c3d-e4f5-a6b7c8d9e0f1">
        <File Id="QtConfFile" Source="$(var.DistDir)/qt.conf" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <!-- Qt platforms plugins -->
  <Fragment>
    <ComponentGroup Id="MuffinPlatformsPlugins" Directory="PlatformsDir">
      <Component Id="QWindows" Guid="*">
        <File Id="QWindowsDll" Source="$(var.DistDir)/platforms/qwindows.dll" />
      </Component>
      <Component Id="QDirect2D" Guid="*">
        <File Id="QDirect2DDll" Source="$(var.DistDir)/platforms/qdirect2d.dll" />
      </Component>
      <Component Id="QMinimal" Guid="*">
        <File Id="QMinimalDll" Source="$(var.DistDir)/platforms/qminimal.dll" />
      </Component>
      <Component Id="QOffscreen" Guid="*">
        <File Id="QOffscreenDll" Source="$(var.DistDir)/platforms/qoffscreen.dll" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <!-- Qt styles plugins -->
  <Fragment>
    <ComponentGroup Id="MuffinStylesPlugins" Directory="StylesDir">
      <Component Id="QModernWindowsStyle" Guid="*">
        <File Id="QModernWindowsStyleDll" Source="$(var.DistDir)/styles/qmodernwindowsstyle.dll" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <!-- Qt imageformats plugins -->
  <Fragment>
    <ComponentGroup Id="MuffinImageformatsPlugins" Directory="ImageformatsDir">
      <Component Id="QGif" Guid="*">
        <File Id="QGifDll" Source="$(var.DistDir)/imageformats/qgif.dll" />
      </Component>
      <Component Id="QIco" Guid="*">
        <File Id="QIcoDll" Source="$(var.DistDir)/imageformats/qico.dll" />
      </Component>
      <Component Id="QSvg" Guid="*">
        <File Id="QSvgDll" Source="$(var.DistDir)/imageformats/qsvg.dll" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
