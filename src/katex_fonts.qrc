    <file alias="KaTeX_Script-Regular.ttf">../third_party/katex/fonts/KaTeX_Script-Regular.ttf</file>
    <file alias="KaTeX_Size1-Regular.ttf">../third_party/katex/fonts/KaTeX_Size1-Regular.ttf</file>
